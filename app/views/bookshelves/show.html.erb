
<div class="container py-1">
  <nav aria-label="breadcrumb" class="mb-4">
  <ol class="breadcrumb d-flex align-items-center p-2 px-3 bg-white rounded-pill shadow-sm border">
    <li class="breadcrumb-item">
      <%= link_to bookshelves_path, class: "text-decoration-none d-flex align-items-center" do %>
        <span class="badge bg-primary rounded-pill me-2">
          <i class="bi bi-grid-3x3-gap-fill"></i>
        </span>
        <span>Estantes</span>
      <% end %>
    </li>
    <li class="px-2 text-muted">
      <i class="bi bi-chevron-right small"></i>
    </li>
    <li class="breadcrumb-item active" aria-current="page">
      <span class="badge bg-light text-dark rounded-pill d-flex align-items-center px-3 py-2 border">
        <i class="bi bi-journal-richtext me-2"></i>
        <%= @bookshelf.name %>
      </span>
    </li>
  </ol>
</nav>

  <div class="d-md-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="mb-1"><%= @bookshelf.name %></h1>
      <p class="text-muted mb-md-0">
        <%= pluralize(@bookshelf.books.count, "livro", "livros") %> na estante
      </p>
    </div>
    
    <div class="d-flex gap-2">
      <% if @bookshelf.user == current_user %>
        <%= link_to edit_bookshelf_path(@bookshelf), class: "btn btn-outline-primary" do %>
          <i class="bi bi-pencil me-1"></i> Editar estante
        <% end %>
        
        <%= button_to bookshelf_path(@bookshelf), method: :delete, 
            class: "btn btn-outline-danger", 
            data: { turbo_confirm: "Tem certeza que deseja excluir esta estante? Isso removerá todos os livros dela." } do %>
          <i class="bi bi-trash me-1"></i> Excluir
        <% end %>
      <% end %>
      
      <%= link_to search_books_path, class: "btn btn-primary" do %>
        <i class="bi bi-plus-lg me-1"></i> Adicionar livros
      <% end %>
    </div>
  </div>

  <!-- Filtros -->
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="row g-2">
        <div class="col-md-4">
          <%= form_with url: bookshelf_path(@bookshelf), method: :get, class: "d-flex" do |f| %>
            <%= f.text_field :search, value: params[:search], class: "form-control me-2", placeholder: "Filtrar por título ou autor" %>
            <%= f.submit "Filtrar", class: "btn btn-outline-primary" %>
          <% end %>
        </div>
        
        <div class="col-md-3">
          <%= form_with url: bookshelf_path(@bookshelf), method: :get, class: "d-flex" do |f| %>
            <%= f.select :status, 
                options_for_select([
                  ['Todos os status', ''],
                  ['Quero ler', 'want_to_read'],
                  ['Estou lendo', 'reading'],
                  ['Já li', 'read']
                ], params[:status]),
                {}, 
                { class: "form-select me-2", onchange: "this.form.submit()" }
            %>
          <% end %>
        </div>
        
        <div class="col-md-3">
          <%= form_with url: bookshelf_path(@bookshelf), method: :get, class: "d-flex" do |f| %>
            <%= f.select :sort, 
                options_for_select([
                  ['Ordenar por título (A-Z)', 'title_asc'],
                  ['Ordenar por título (Z-A)', 'title_desc'],
                  ['Adicionados recentemente', 'added_desc'],
                  ['Adicionados primeiro', 'added_asc']
                ], params[:sort] || 'added_desc'),
                {}, 
                { class: "form-select", onchange: "this.form.submit()" }
            %>
          <% end %>
        </div>
        
        <% if params[:search].present? || params[:status].present? || params[:sort].present? %>
          <div class="col-md-2">
            <%= link_to "Limpar filtros", bookshelf_path(@bookshelf), class: "btn btn-outline-secondary w-100" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Livros na estante -->
  <% if @bookshelf_items.any? %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-4">
      <% @bookshelf_items.each do |item| %>
        <div class="col">
          <div class="card h-100 shadow-sm">
            <div class="row g-0">
              <div class="col-4">
                <% if item.book.thumbnail_url.present? %>
                  <img src="<%= item.book.thumbnail_url %>" alt="<%= item.book.title %>" class="img-fluid rounded-start h-100 object-fit-cover">
                <% else %>
                  <div class="bg-light h-100 d-flex align-items-center justify-content-center rounded-start">
                    <i class="bi bi-book fs-1 text-secondary"></i>
                  </div>
                <% end %>
              </div>
              <div class="col-8">
                <div class="card-body">
                  <h5 class="card-title text-truncate"><%= item.book.title %></h5>
                  <% if item.book.authors.present? %>
                    <p class="card-text text-truncate"><small class="text-muted">por <%= item.book.authors %></small></p>
                  <% end %>
                  
                  <div class="mb-3">
                    <% status_badge_class = case item.status
                                           when 'want_to_read' then 'bg-info'
                                           when 'reading' then 'bg-warning'
                                           when 'read' then 'bg-success'
                                           else 'bg-secondary'
                                           end %>
                    
                    <% status_text = case item.status
                                    when 'want_to_read' then 'Quero ler'
                                    when 'reading' then 'Estou lendo'
                                    when 'read' then 'Já li'
                                    else 'Quero ler'
                                    end %>
                    
                    <span class="badge <%= status_badge_class %>"><%= status_text %></span>
                    
                    <small class="text-muted ms-2">
                      Adicionado em <%= l(item.created_at.to_date, format: :short) %>
                    </small>
                  </div>
                  
                  <div class="d-flex gap-1">
                    <%= link_to book_path(item.book), class: "btn btn-sm btn-outline-primary" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    
                    <div class="dropdown">
                      <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" id="statusDropdown<%= item.id %>" data-bs-toggle="dropdown" aria-expanded="false">
                        Status
                      </button>
                      <ul class="dropdown-menu" aria-labelledby="statusDropdown<%= item.id %>">
                        <% ['want_to_read', 'reading', 'read'].each do |status| %>
                          <% status_text = { 'want_to_read' => 'Quero ler', 'reading' => 'Estou lendo', 'read' => 'Já li' }[status] %>
                          <li>
                            <%= link_to status_text, 
                                      update_book_status_bookshelf_path(@bookshelf, book_id: item.book.id, status: status),
                                      data: { turbo_method: :post },
                                      
                                      class: "dropdown-item #{'active' if item.status == status}" %>
                          </li>
                        <% end %>
                      </ul>
                    </div>
                    
                    <%= button_to remove_book_bookshelf_path(@bookshelf, book_id: item.book.id), 
                                method: :delete, 
                                class: "btn btn-sm btn-outline-danger", 
                                data: { turbo_confirm: "Remover este livro da estante?" } do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    
    <!-- Paginação -->
    <div class="d-flex justify-content-center">
      <%= paginate @bookshelf_items, theme: 'bootstrap-5' %>
    </div>
  <% else %>
    <div class="text-center py-5">
      <i class="bi bi-journal-bookmark fs-1 text-secondary mb-3"></i>
      <h3>Esta estante está vazia</h3>
      <p class="text-muted mb-4">Adicione livros à sua estante para começar a organizar suas leituras</p>
      <%= link_to search_books_path, class: "btn btn-primary" do %>
        <i class="bi bi-search me-1"></i> Buscar Livros
      <% end %>
    </div>
  <% end %>
</div>