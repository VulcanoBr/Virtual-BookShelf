<% content_for :title, "Perfil" %>

<div class="row">
  <div class="col-md-4">
    <div class="card mb-4">
      <div class="card-header">
        <h4 class="mb-0">Informações pessoais</h4>
      </div>
      <div class="card-body">
        <h5 class="card-title"><%= @user.full_name %></h5>
        <p class="card-text"><strong>E-mail:</strong> <%= @user.email %></p>
        <p class="card-text">
          <strong>Membro desde:</strong> <%= @user.created_at.strftime("%d/%m/%Y") %>
        </p>
        
        <% if @user == current_user %>
          <%= link_to "Editar perfil", edit_user_path(@user), class: "btn btn-outline-primary" %>
        <% end %>
      </div>
    </div>
  </div>
  
  <div class="col-md-8">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Minhas Estantes</h4>
        <% if @user == current_user %>
          <%= link_to "Ver todas", bookshelves_path, class: "btn btn-sm btn-outline-primary" %>
        <% end %>
      </div>
      <div class="card-body">
        <% if @user.bookshelves.any? %>
          <div class="list-group">
            <% @user.bookshelves.each do |bookshelf| %>
              <%= link_to bookshelf_path(bookshelf), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
                <%= bookshelf.name %>
                <span class="badge bg-primary rounded-pill"><%= bookshelf.books.count %></span>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p>Nenhuma estante criada ainda.</p>
        <% end %>
        
        <% if @user == current_user %>
          <div class="mt-3">
            <%= link_to "Nova estante", new_bookshelf_path, class: "btn btn-success" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>