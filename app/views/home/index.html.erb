
<div class="jumbotron bg-light p-1 rounded">
  <h1 class="display-4">Bem-vindo à Minha Estante Virtual</h1>
  <p class="lead">Organize sua coleção de livros, descubra novas obras e compartilhe suas leituras favoritas.</p>
  <hr class="my-4">
  <p>Busque por título, autor ou ISBN e adicione livros à sua estante virtual.</p>
  <%= form_with url: search_books_path, method: :get, class: "d-flex col-md-8 col-lg-6", data: { turbo: false } do |f| %>
    <%= f.select :type, options_for_select([['Título', 'title'], ['Autor', 'author'], ['ISBN', 'isbn']]), {}, class: "form-select me-2", style: "width: auto;" %>
    <%= f.text_field :q, placeholder: "Buscar livros...", class: "form-control me-2" %>
    <%= f.submit "Buscar", class: "btn btn-primary" %>
  <% end %>
</div>

<% if logged_in? && @user_bookshelves.any? %>
  <section class="mt-5">
    <h2>Suas Estantes</h2>
    <div class="row">
      <% @user_bookshelves.each do |bookshelf| %>
        <div class="col-md-6">
          <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h5 class="mb-0"><%= bookshelf.name %></h5>
              <%= link_to "Ver tudo", bookshelf_path(bookshelf), class: "btn btn-sm btn-outline-primary" %>
            </div>
            <div class="card-body">
              <% if bookshelf.books.any? %>
                <div class="row">
                  <% bookshelf.books.limit(4).each do |book| %>
                    <div class="col-6 col-md-3 mb-3">
                      <% if book.thumbnail_url.present? %>
                        <%= link_to book_path(book) do %>
                          <%= image_tag book.thumbnail_url, class: "img-fluid rounded", alt: book.title %>
                        <% end %>
                      <% else %>
                        <div class="bg-light d-flex align-items-center justify-content-center rounded" style="height: 120px;">
                          <i class="bi bi-book fs-1 text-secondary"></i>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <p>Esta estante está vazia. <%= link_to "Adicione livros!", books_path %></p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<section class="mt-5">
  <h2>Livros Recentes</h2>
  <div class="row row-cols-1 row-cols-md-3 row-cols-lg-6 g-4">
    <% @recent_books.each do |book| %>
      <div class="col">
        <%= render 'shared/book_card', book: book %>
      </div>
    <% end %>
  </div>
  <div class="text-center mt-4">
    <%= link_to "Ver mais livros", books_path, class: "btn btn-primary" %>
  </div>
</section>

<% unless logged_in? %>
  <section class="mt-5 bg-light p-5 rounded">
    <h2>Entre agora mesmo</h2>
    <p>Crie uma conta para adicionar livros às suas estantes pessoais.</p>
    <div class="d-flex gap-2">
      <%= link_to "Entrar", login_path, class: "btn btn-primary" %>
      <%= link_to "Cadastrar", signup_path, class: "btn btn-outline-primary" %>
    </div>
  </section>
<% end %>