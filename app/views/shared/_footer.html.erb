        <ul class="list-unstyled">
          <li><i class="bi bi-envelope"></i> contato@virtualbookshelf.com</li>
          <li><i class="bi bi-telephone"></i> (11) 99999-9999</li>
        </ul>
      </div>
    </div>
    <hr>
    <div class="text-center">
      <p>&copy; <%= Date.current.year %> <i class="bi bi-book"></i> Virtual BookShelf. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>