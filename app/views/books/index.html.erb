
<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Livros Disponíveis</h1>
    <div>
      <%= link_to search_books_path, class: "btn btn-primary" do %>
        <i class="bi bi-search me-1"></i> Buscar Livros
      <% end %>
    </div>
  </div>

  <% if @books.any? %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
      <% @books.each do |book| %>
        <div class="col">
          <div class="card h-100 shadow-sm">
            <div class="position-relative" style="height: 200px;">
              <% if book.thumbnail_url.present? %>
                <img src="<%= book.thumbnail_url %>" alt="<%= book.title %>" class="card-img-top h-100 object-fit-cover">
              <% else %>
                <div class="h-100 d-flex align-items-center justify-content-center bg-light">
                  <i class="bi bi-book fs-1 text-secondary"></i>
                </div>
              <% end %>
            </div>
            
            <div class="card-body">
              <h5 class="card-title text-truncate"><%= book.title %></h5>
              <% if book.authors.present? %>
                <p class="card-text text-truncate"><small class="text-muted">por <%= book.authors %></small></p>
              <% end %>
              
              <% if book.description.present? %>
                <p class="card-text text-truncate"><%= book.description %></p>
              <% end %>
            </div>
            
            <div class="card-footer bg-transparent">
              <%= link_to "Ver detalhes", book_path(book[:id]), class: "btn btn-outline-primary btn-sm w-100" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Paginação -->
    <div class="d-flex justify-content-center mt-4">
      <%= paginate @books, theme: 'bootstrap-5' %>
    </div>
  <% else %>
    <div class="alert alert-info">
      <p class="mb-0">Ainda não há livros disponíveis.</p>
    </div>
    
    <div class="text-center py-5">
      <i class="bi bi-book fs-1 text-secondary mb-3"></i>
      <h3>Comece adicionando livros à biblioteca</h3>
      <p class="text-muted mb-4">Use a função de busca para encontrar seus livros favoritos</p>
      <%= link_to search_books_path, class: "btn btn-primary" do %>
        <i class="bi bi-search me-1"></i> Buscar Livros
      <% end %>
    </div>
  <% end %>
</div>