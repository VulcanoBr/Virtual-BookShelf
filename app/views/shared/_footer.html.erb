    <div class="row">
      <div class="col-md-6">
        <h5><i class="bi bi-book"></i> Virtual BookShelf</h5>
        <p>Seu catálogo pessoal de livros online.</p>
      </div>
      <div class="col-md-3">
        <h5>Links</h5>
        <ul class="list-unstyled">
          <li><%= link_to "Início", root_path, class: "text-light" %></li>
