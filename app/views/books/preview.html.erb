<div class="container py-1">
  <% if notice %>
    <div class="alert alert-success" role="alert">
      <%= notice %>
    </div>
  <% end %>
  <% if alert %>
    <div class="alert alert-danger" role="alert">
      <%= alert %>
    </div>
  <% end %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><%= @book_data[:title] %></h1>
    <div>
      <% if @existing_book %>
        <%= link_to "Ver no catálogo", book_path(@existing_book), class: "btn btn-success" %>
      
      <% end %>
    </div>
  </div>

  <% if @book_data[:subtitle].present? %>
    <h2 class="text-muted fs-4 mb-4"><%= @book_data[:subtitle] %></h2>
  <% end %>

  <div class="row">
    <div class="col-md-4">
      <% if @book_data[:thumbnail].present? %>
        <img src="<%= @book_data[:thumbnail] %>" alt="<%= @book_data[:title] %>" class="img-fluid rounded shadow-sm">
      <% else %>
        <div class="bg-light d-flex align-items-center justify-content-center rounded shadow-sm" style="height: 300px;">
          <i class="bi bi-book-half fs-1 text-secondary"></i>
        </div>
      <% end %>
      
      <!-- Adicionar à estante diretamente da página de preview -->
      <% if current_user.bookshelves.any? %>
        <div class="card shadow-sm mt-4">
          <div class="card-header">
            <h5 class="card-title mb-0">Adicionar à Estante</h5>
          </div>
          <div class="card-body">
            <%= form_with(url: add_to_bookshelf_book_path(params[:id]), method: :post) do |f| %>
              <div class="mb-3">
                <%= f.label :bookshelf_id, "Selecione a Estante:", class: "form-label" %>
                <%= f.collection_select :bookshelf_id, current_user.bookshelves, :id, :name, { prompt: "Escolha uma estante" }, class: "form-select", required: true %>
              </div>
              <div class="mb-3">
                <%= f.label :status, "Status (Opcional):", class: "form-label" %>
                <%= f.select :status, 
                             options_for_select(BookshelfItem.validators_on(:status).first.options[:in].map { |s| [s.humanize, s] }, nil), 
                             { include_blank: 'Nenhum (padrão)' }, 
                             class: "form-select" %>
              </div>
              <%= f.submit "Adicionar à Estante", class: "btn btn-primary w-100" %>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="card shadow-sm mt-4">
          <div class="card-body">
            <p class="mb-0">Você ainda não criou nenhuma estante. <%= link_to "Crie uma agora!", new_bookshelf_path %> para poder adicionar livros.</p>
          </div>
        </div>
      <% end %>
    </div>
    <div class="col-md-8">
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <% if @book_data[:authors].present? %>
            <p><strong>Autores:</strong> <%= @book_data[:authors].join(', ') %></p>
          <% end %>
          
          <% if @book_data[:publisher].present? %>
            <p><strong>Editora:</strong> <%= @book_data[:publisher] %></p>
          <% end %>
          
          <% if @book_data[:published_date].present? %>
            <p><strong>Data de Publicação:</strong> <%= @book_data[:published_date] %></p>
          <% end %>

          <% if @book_data[:language].present? %>
            <p><strong>Idioma:</strong> <%= display_language(@book_data[:language]) %></p>
          <% end %>
          
          <% if @book_data[:isbn].present? %>
            <p><strong>ISBN:</strong> <%= @book_data[:isbn] %></p>
          <% end %>
          
          <% if @book_data[:page_count].present? %>
            <p><strong>Páginas:</strong> <%= @book_data[:page_count] %></p>
          <% end %>
          
          <% if @book_data[:categories].present? %>
            <p><strong>Categorias:</strong> <%= @book_data[:categories].join(', ') %></p>
          <% end %>
        </div>
      </div>

      <% if @book_data[:description].present? %>
        <div class="card shadow-sm mb-4">
          <div class="card-header">
            <h5 class="card-title mb-0">Descrição</h5>
          </div>
          <div class="card-body">
            <%= simple_format(@book_data[:description]) %>
          </div>
        </div>
      <% end %>

      <% if @book_data[:preview_link].present? %>
        <a href="<%= @book_data[:preview_link] %>" target="_blank" class="btn btn-outline-primary mb-3">
          <i class="bi bi-eye-fill me-1"></i> Prévia no Google Books
        </a>
      <% end %>

      <hr>
      <div class="mt-3">
        <%= link_to "Voltar para a busca", search_books_path, class: "btn btn-secondary" %>
        <%= link_to "Ver todos os livros", books_path, class: "btn btn-outline-secondary ms-2" %>
      </div>
    </div>
  </div>
</div>