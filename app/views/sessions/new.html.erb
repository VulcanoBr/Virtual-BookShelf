<% content_for :title, "Login" %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card shadow">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Entrar na Minha Estante Virtual</h4>
      </div>
      <div class="card-body">
        <%= form_with url: login_path, method: :post do |f| %>
          <div class="mb-3">
            <%= f.label :email, "E-mail", class: "form-label" %>
            <%= f.email_field :email, class: "form-control", required: true, autofocus: true %>
          </div>
          
          <div class="mb-3">
            <%= f.label :password, "Senha", class: "form-label" %>
            <%= f.password_field :password, class: "form-control", required: true %>
          </div>
          
          <div class="mb-3 form-check">
            <%= f.check_box :remember_me, class: "form-check-input" %>
            <%= f.label :remember_me, "Lembrar de mim", class: "form-check-label" %>
          </div>
          
          <div class="d-grid">
            <%= f.submit "Entrar", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
      <div class="card-footer text-center">
        <p class="mb-0">Não tem uma conta? <%= link_to "Cadastre-se", signup_path %></p>
      </div>
    </div>
  </div>
</div>