<% content_for :title, "Cadastro" %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Criar uma Conta</h4>
      </div>
      <div class="card-body">
        <%= form_with model: @user, url: users_path do |f| %>
          <% if @user.errors.any? %>
            <div class="alert alert-danger">
              <h5><%= pluralize(@user.errors.count, "erro") %> impediu o cadastro:</h5>
              <ul>
                <% @user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          
          <div class="row">
            <div class="col-md-6 mb-3">
              <%= f.label :first_name, "Nome", class: "form-label" %>
              <%= f.text_field :first_name, class: "form-control", required: true, autofocus: true %>
            </div>
            
            <div class="col-md-6 mb-3">
              <%= f.label :last_name, "Sobrenome", class: "form-label" %>
              <%= f.text_field :last_name, class: "form-control" %>
            </div>
          </div>
          
          <div class="mb-3">
            <%= f.label :email, "E-mail", class: "form-label" %>
            <%= f.email_field :email, class: "form-control", required: true %>
          </div>
          
          <div class="mb-3">
            <%= f.label :password, "Senha", class: "form-label" %>
            <%= f.password_field :password, class: "form-control", required: true, minlength: 6 %>
            <div class="form-text">A senha deve ter pelo menos 6 caracteres.</div>
          </div>
          
          <div class="mb-3">
            <%= f.label :password_confirmation, "Confirmar senha", class: "form-label" %>
            <%= f.password_field :password_confirmation, class: "form-control", required: true %>
          </div>
          
          <div class="d-grid">
            <%= f.submit "Cadastrar", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
      <div class="card-footer text-center">
        <p class="mb-0">Já tem uma conta? <%= link_to "Entrar", login_path %></p>
      </div>
    </div>
  </div>
</div>